GEMINI_API_KEY=your-gemini-api-key-here

# Optional: set to true when you wire official DB Insurance domain search.
ENABLE_OFFICIAL_WEB_SEARCH=false

# Kakao Login REST API Key
KAKAO_REST_API_KEY=your-kakao-rest-api-key-here

# Firebase Firestore Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id-here

# Admin Dashboard Password
ADMIN_PASSWORD=your-admin-password-here

